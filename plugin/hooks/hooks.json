{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/worklog-journal.sh",
            "timeout": 5,
            "statusMessage": "Loading worklog journaling..."
          }
        ]
      }
    ]
  }
}
